<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="boarderPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Rooms.ShopController">
   <center>
      <TableView fx:id="shopTableView" onMouseClicked="#updateDiscriptionLabel" prefHeight="209.0" prefWidth="368.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="tableViewCollumItem" prefWidth="160.60000002384186" text="Item" />
          <TableColumn fx:id="tableViewCollumPrice" prefWidth="62.199981689453125" text="Preis" />
        </columns>
      </TableView>
   </center>
   <top>
      <HBox prefHeight="66.0" prefWidth="600.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="playerHealthLabel" alignment="BOTTOM_LEFT" prefHeight="53.0" prefWidth="264.0" text="Label" />
            <Label alignment="CENTER" prefHeight="18.0" prefWidth="62.0" text="Shop">
               <font>
                  <Font size="24.0" />
               </font></Label>
            <Label fx:id="playerGoldLable" alignment="BOTTOM_RIGHT" prefHeight="50.0" prefWidth="265.0" text="Label" />
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox prefHeight="125.0" prefWidth="600.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="discriptionLable" alignment="TOP_LEFT" prefHeight="126.0" prefWidth="448.0" text="Label" />
            <GridPane prefHeight="126.0" prefWidth="258.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Button fx:id="buyButton" mnemonicParsing="false" onAction="#buySelectedItem" text="Kaufen" />
                  <Button fx:id="nextRoomButton" mnemonicParsing="false" onAction="#nextRoom" text="nächster Raum" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Button fx:id="inventoryButton" mnemonicParsing="false" onAction="#showInventory" text="Inventar" GridPane.rowIndex="1" />
                  <Button fx:id="buyAndEquipButton" mnemonicParsing="false" onAction="#byAndEquipSelectetItem" text="buy&amp;equip" GridPane.columnIndex="1" />
               </children>
            </GridPane>
         </children>
      </HBox>
   </bottom>
</BorderPane>
