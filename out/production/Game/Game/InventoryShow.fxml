<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Game.InventoryShow">
   <top>
       <HBox>
         <Label fx:id="playerHealt" alignment="BOTTOM_LEFT" prefHeight="48.0" prefWidth="239.0" text="Label" translateX="10.0" />
           <Label alignment="CENTER" prefHeight="48.0" prefWidth="162.0" style="-fx-font-size: 18; -fx-padding: 10;" text="Inventory" BorderPane.alignment="CENTER" />
         <Label fx:id="playerGold" alignment="BOTTOM_RIGHT" contentDisplay="BOTTOM" prefHeight="48.0" prefWidth="241.0" text="Label" translateX="-10.0" />
       </HBox>
   </top>
   <center>
      <VBox fx:id="itemList" spacing="5" style="-fx-padding: 10;">
         <children>
            <TabPane fx:id="inventoryTabPane" prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE">
              <tabs>
                <Tab text="Weapons">
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <ListView fx:id="weaponsView" layoutX="14.0" layoutY="14.0" onMouseClicked="#listedViewShowItemDiscription" prefHeight="156.0" prefWidth="200.0" />
                           </children></AnchorPane>
                  </content>
                </Tab>
                <Tab text="Armor">
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <ListView fx:id="armorView" layoutX="14.0" layoutY="8.0" onMouseClicked="#listedViewShowItemDiscription" prefHeight="156.0" prefWidth="200.0" />
                           </children></AnchorPane>
                  </content>
                </Tab>
                <Tab fx:id="consumablesTab" text="Consumables">
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                        <children>
                            <ListView fx:id="consumableView" layoutX="14.0" layoutY="8.0" onMouseClicked="#listedViewShowItemDiscription" prefHeight="156.0" prefWidth="200.0" />
                        </children></AnchorPane>
                </Tab>
              </tabs>
            </TabPane>
            <HBox prefHeight="124.0" prefWidth="579.0">
               <children>
                  <Label fx:id="discriptionText" alignment="TOP_LEFT" prefHeight="120.0" prefWidth="469.0" text="Discription" />
                  <GridPane prefHeight="124.0" prefWidth="253.0">
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <Button fx:id="backButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#closeInventory" text="Zurück" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Button fx:id="useButton" mnemonicParsing="false" onAction="#useSelectetItem" text="Benutzen" />
                     </children>
                  </GridPane>
               </children>
            </HBox>
         </children></VBox>
   </center>
</BorderPane>
